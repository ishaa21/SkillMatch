# ========================================
# AI Service Configuration
# ========================================

# Server
PORT=8000
HOST=0.0.0.0
ENV=development
LOG_LEVEL=INFO

# ML Model
MODEL_NAME=all-MiniLM-L6-v2

# Matching Weights (must sum to 1.0)
WEIGHT_SKILLS=0.40
WEIGHT_RESUME=0.30
WEIGHT_DOMAIN=0.15
WEIGHT_LOCATION=0.15

# Performance
MAX_RECOMMENDATIONS=20
MIN_SCORE_THRESHOLD=10
REQUEST_TIMEOUT_SECONDS=30

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# CORS
ALLOWED_ORIGINS=*
